{
  "Inputs": {
    "SRC_IN": {
      "name": "SRC_IN",
      "format": "cobol",
      "path": "APP/SRC/DAILY/FILE",
      "dataset": "APP.SRC.DAILY.FILE(0)",
      "copybook": "GENIN01",
      "cobrix": {
        "copybook_path": "UCDXFDA-BANK/GENIN01.cpy",
        "encoding": "cp037",
        "record_format": "F",
        "file_start_offset": 0,
        "file_end_offset": 0,
        "generate_record_id": false
      },
      "fields": [],
      "metadata": {}
    },
    "CTL_PARM": {
      "name": "CTL_PARM",
      "format": "fixed",
      "path": "ENV/PARMLIB/CTLGEN01",
      "dataset": "ENV.PARMLIB(CTLGEN01)",
      "fields": [
        {
          "name": "WS_CTL_PARM",
          "type": "string",
          "start": 1,
          "length": 8
        },
        {
          "name": "WS_BYPASS_DATE",
          "type": "string",
          "start": 9,
          "length": 8
        }
      ],
      "metadata": {}
    }
  },
  "Outputs": {
    "DATA_OUT": {
      "name": "DATA_OUT",
      "format": "parquet",
      "path": "APPHLQ/TGT/DATA/DLY",
      "dataset": "APPHLQ.TGT.DATA.DLY",
      "write_mode": "overwrite",
      "copybook": "GENOUT01",
      "fields": [
        {
          "name": "GENOUT_DATE",
          "type": "int"
        },
        {
          "name": "GENOUT_NUM1",
          "type": "int"
        },
        {
          "name": "GENOUT_TEXT",
          "type": "string"
        },
        {
          "name": "GENOUT_FILL",
          "type": "string"
        }
      ],
      "output_columns": [
        "GENOUT_DATE",
        "GENOUT_NUM1",
        "GENOUT_TEXT",
        "GENOUT_FILL"
      ],
      "metadata": {}
    },
    "CNT_OUT": {
      "name": "CNT_OUT",
      "format": "parquet",
      "path": "APPHLQ/TGT/CNT/DLY",
      "dataset": "APPHLQ.TGT.CNT.DLY",
      "write_mode": "overwrite",
      "copybook": "GENCNT01D",
      "fields": [
        {
          "name": "CNT_COUNT_RECORDS",
          "type": "int"
        },
        {
          "name": "CNT_EFFECTIVE-DATE",
          "type": "string"
        },
        {
          "name": "CNT_AS-OF-DATE",
          "type": "string"
        },
        {
          "name": "CNT_SOURCE-CODE",
          "type": "string"
        },
        {
          "name": "CNT_SOURCE-ID",
          "type": "string"
        }
      ],
      "output_columns": [
        "CNT_COUNT_RECORDS",
        "CNT_EFFECTIVE-DATE",
        "CNT_AS-OF-DATE",
        "CNT_SOURCE-CODE",
        "CNT_SOURCE-ID"
      ],
      "metadata": {}
    }
  },
  "Transformations": {
    "description": "Replicates PGMFMT01 formatting and date validation logic",
    "steps": [
      {
        "id": "filter_header_trailer",
        "description": "Separate Header, Detail, and Trailer records based on GENIN01 redefine patterns",
        "type": "filter",
        "source_inputs": [
          "SRC_IN"
        ],
        "logic": {
          "detail_condition": "GENIN_HDR_TYPE NOT IN ('HD', 'TLR') AND GENIN_DET_DATE IS NOT NULL"
        },
        "output_alias": "detail_records"
      },
      {
        "id": "map_detail_logic",
        "description": "Map GENIN detail fields to GENOUT format with numeric validation",
        "type": "select",
        "source_inputs": [
          "detail_records"
        ],
        "logic": {
          "columns": {
            "GENOUT_DATE": "GENIN_DET_DATE",
            "GENOUT_NUM1": "GENIN_DET_NUM1",
            "GENOUT_TEXT": "GENIN_DET_TEXT",
            "GENOUT_FILL": "GENIN_DET_FILL"
          }
        },
        "output_alias": "formatted_data"
      },
      {
        "id": "aggregate_counts",
        "description": "Calculate record counts and extract effective dates for trailer generation",
        "type": "aggregate",
        "source_inputs": [
          "detail_records"
        ],
        "logic": {
          "functions": [
            {
              "column": "*",
              "agg": "count",
              "alias": "WS_DATA_COUNT"
            }
          ]
        },
        "output_alias": "summary_stats"
      },
      {
        "id": "generate_control_file",
        "description": "Create count output record following 1900-EOJ logic",
        "type": "custom",
        "source_inputs": [
          "summary_stats",
          "CTL_PARM"
        ],
        "logic": {
          "action": "Construct CNT-COUNT-OUT-RECORD using summary stats and constants 999 and GENERIC FEED",
          "mapping": {
            "CNT_COUNT_RECORDS": "summary_stats.WS_DATA_COUNT",
            "CNT_SOURCE_CODE": "999",
            "CNT_SOURCE_ID": "GENERIC FEED"
          }
        },
        "output_alias": "final_counts"
      }
    ]
  }
}