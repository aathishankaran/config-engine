{
  "Inputs": {
    "SRCIN": {
      "name": "SRCIN",
      "format": "cobol",
      "path": "data/APP.SRC.DAILY.FILE",
      "dataset": "APP.SRC.DAILY.FILE(0)",
      "copybook": "GENIN01",
      "cobrix": {
        "copybook_path": "copybooks/GENIN01.cpy",
        "encoding": "cp037",
        "record_format": "FB",
        "file_start_offset": 0,
        "file_end_offset": 0,
        "generate_record_id": false
      },
      "fields": [
        {
          "name": "GENIN_HDR_TYPE",
          "type": "string",
          "start": 1,
          "length": 2
        },
        {
          "name": "GENIN_HDR_DATE",
          "type": "int",
          "start": 3,
          "length": 8
        },
        {
          "name": "GENIN_HDR_FILL",
          "type": "string",
          "start": 11,
          "length": 169
        },
        {
          "name": "GENIN_DET_DATE",
          "type": "int",
          "start": 1,
          "length": 8
        },
        {
          "name": "GENIN_DET_NUM1",
          "type": "int",
          "start": 9,
          "length": 7
        },
        {
          "name": "GENIN_DET_TEXT",
          "type": "string",
          "start": 16,
          "length": 40
        },
        {
          "name": "GENIN_DET_FILL",
          "type": "string",
          "start": 56,
          "length": 145
        },
        {
          "name": "GENIN_TLR_TYPE",
          "type": "string",
          "start": 1,
          "length": 3
        },
        {
          "name": "GENIN_TLR_COUNT",
          "type": "int",
          "start": 4,
          "length": 10
        },
        {
          "name": "GENIN_TLR_FILL",
          "type": "string",
          "start": 14,
          "length": 167
        }
      ]
    },
    "LSTRUN_IN": {
      "name": "LSTRUN_IN",
      "format": "fixed",
      "path": "data/APP.BKUP.LASTRUN.FILE",
      "dataset": "APP.BKUP.LASTRUN.FILE(0)",
      "fields": [
        {
          "name": "RECORD_DATA",
          "type": "string",
          "start": 1,
          "length": 80
        }
      ]
    },
    "CTLPARM_IN": {
      "name": "CTLPARM_IN",
      "format": "fixed",
      "path": "data/ENV.PARMLIB",
      "dataset": "ENV.PARMLIB(CTLGEN01)",
      "fields": [
        {
          "name": "CTL_FEC",
          "type": "string",
          "start": 1,
          "length": 80
        }
      ]
    }
  },
  "Outputs": {
    "DATAOUT": {
      "name": "DATAOUT",
      "format": "parquet",
      "path": "data/APPHLQ.TGT.DATA.DLY",
      "dataset": "APPHLQ.TGT.DATA.DLY",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "GENOUT_DATE",
          "type": "int"
        },
        {
          "name": "GENOUT_NUM1",
          "type": "int"
        },
        {
          "name": "GENOUT_TEXT",
          "type": "string"
        },
        {
          "name": "GENOUT_FILL",
          "type": "string"
        }
      ]
    },
    "CNTOUT": {
      "name": "CNTOUT",
      "format": "parquet",
      "path": "data/APPHLQ.TGT.CNT.DLY",
      "dataset": "APPHLQ.TGT.CNT.DLY",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "CNT_COUNT_RECORDS",
          "type": "int"
        },
        {
          "name": "CNT_EFFECTIVE_DATE",
          "type": "string"
        },
        {
          "name": "CNT_AS_OF_DATE",
          "type": "string"
        },
        {
          "name": "CNT_SOURCE_CODE",
          "type": "string"
        },
        {
          "name": "CNT_SOURCE_ID",
          "type": "string"
        }
      ]
    },
    "INBKUP": {
      "name": "INBKUP",
      "format": "parquet",
      "path": "data/APP.BKUP.DLY.INPUT",
      "dataset": "APP.BKUP.DLY.INPUT(+1)",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "RECORD_DATA",
          "type": "string"
        }
      ]
    },
    "DATABKUP_DLY": {
      "name": "DATABKUP_DLY",
      "format": "parquet",
      "path": "data/APP.BKUP.DLY.DATA",
      "dataset": "APP.BKUP.DLY.DATA(+1)",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "GENOUT_DATE",
          "type": "int"
        },
        {
          "name": "GENOUT_NUM1",
          "type": "int"
        }
      ]
    },
    "CNTBKUP_DLY": {
      "name": "CNTBKUP_DLY",
      "format": "parquet",
      "path": "data/APP.BKUP.MTH.CNT",
      "dataset": "APP.BKUP.MTH.CNT(+1)",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "CNT_COUNT_RECORDS",
          "type": "int"
        }
      ]
    },
    "DATABKUP_MTH": {
      "name": "DATABKUP_MTH",
      "format": "parquet",
      "path": "data/APP.BKUP.MTH.DATA",
      "dataset": "APP.BKUP.MTH.DATA(+1)",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "GENOUT_DATE",
          "type": "int"
        },
        {
          "name": "GENOUT_NUM1",
          "type": "int"
        }
      ]
    },
    "CNTBKUP_MTH": {
      "name": "CNTBKUP_MTH",
      "format": "parquet",
      "path": "data/APP.BKUP.MTH.CNT",
      "dataset": "APP.BKUP.MTH.CNT(+1)",
      "write_mode": "overwrite",
      "fields": [
        {
          "name": "CNT_COUNT_RECORDS",
          "type": "int"
        }
      ]
    }
  },
  "Transformations": {
    "description": "Daily transaction formatting and backup process with conditional monthly triggers.",
    "steps": [
      {
        "id": "S05_P15_date_check",
        "description": "S05 GENDATCHK P15: Validates date from input file against last run.",
        "type": "custom",
        "source_inputs": [
          "SRCIN",
          "LSTRUN_IN"
        ],
        "logic": {
          "operation": "validate_date",
          "parameters": {
            "program": "PGMDTCK1"
          }
        },
        "output_alias": "validated_date_status"
      },
      {
        "id": "S10_P05_format",
        "description": "S10 GENFMT01 P05: Main COBOL formatter PGMFMT01 creates transaction data.",
        "type": "select",
        "source_inputs": [
          "SRCIN"
        ],
        "logic": {
          "expressions": [
            {
              "target": "GENOUT_DATE",
              "expression": "GENIN_DET_DATE",
              "operation": "move"
            },
            {
              "target": "GENOUT_NUM1",
              "expression": "GENIN_DET_NUM1",
              "operation": "move"
            },
            {
              "target": "GENOUT_TEXT",
              "expression": "GENIN_DET_TEXT",
              "operation": "move"
            },
            {
              "target": "GENOUT_FILL",
              "expression": "GENIN_DET_FILL",
              "operation": "move"
            }
          ]
        },
        "output_alias": "DATAOUT"
      },
      {
        "id": "S10_P05_counts",
        "description": "S10 GENFMT01 P05: Generates trailer count record.",
        "type": "aggregate",
        "source_inputs": [
          "SRCIN"
        ],
        "logic": {
          "group_by": [],
          "aggregations": [
            {
              "field": "GENIN_DET_REC",
              "operation": "count",
              "alias": "CNT_COUNT_RECORDS"
            }
          ]
        },
        "output_alias": "CNTOUT"
      },
      {
        "id": "S15_a_backup_input",
        "description": "S15 GENBKUP02 INBKUP: Backup of raw daily input file.",
        "type": "select",
        "source_inputs": [
          "SRCIN"
        ],
        "logic": {
          "columns": [
            "*"
          ]
        },
        "output_alias": "INBKUP"
      },
      {
        "id": "S15_b_backup_data",
        "description": "S15 GENBKUP02 DATABKUP: Daily backup of formatted data.",
        "type": "select",
        "source_inputs": [
          "DATAOUT"
        ],
        "logic": {
          "columns": [
            "GENOUT_DATE",
            "GENOUT_NUM1"
          ]
        },
        "output_alias": "DATABKUP_DLY"
      },
      {
        "id": "S15_c_backup_cnt",
        "description": "S15 GENBKUP02 CNTBKUP: Daily backup of count file.",
        "type": "select",
        "source_inputs": [
          "CNTOUT"
        ],
        "logic": {
          "columns": [
            "CNT_COUNT_RECORDS"
          ]
        },
        "output_alias": "CNTBKUP_DLY"
      },
      {
        "id": "S20_conditional_filter",
        "description": "S20 Condition: Executes if S10 return code indicates month-end (RC=5).",
        "type": "filter",
        "source_inputs": [
          "DATAOUT"
        ],
        "logic": {
          "conditions": [
            {
              "field": "LAST_BUS_DAY_INDC",
              "operation": "==",
              "value": "Y"
            }
          ]
        },
        "output_alias": "month_end_trigger_data"
      },
      {
        "id": "S20_b_monthly_data_backup",
        "description": "S20 GENBKUP02 DATABKUP: Monthly-specific backup of formatted data.",
        "type": "select",
        "source_inputs": [
          "month_end_trigger_data"
        ],
        "logic": {
          "columns": [
            "GENOUT_DATE",
            "GENOUT_NUM1"
          ]
        },
        "output_alias": "DATABKUP_MTH"
      },
      {
        "id": "S20_c_monthly_cnt_backup",
        "description": "S20 GENBKUP02 CNTBKUP: Monthly-specific backup of count file.",
        "type": "select",
        "source_inputs": [
          "CNTOUT"
        ],
        "logic": {
          "columns": [
            "CNT_COUNT_RECORDS"
          ]
        },
        "output_alias": "CNTBKUP_MTH"
      }
    ]
  }
}